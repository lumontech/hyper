# ─────────────────────────────────────────────────────────────────────
# Hyperliquid Bot — Environment Configuration
# Copy to .env and NEVER commit. .env is in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# === Network ===
# testnet | mainnet  — default mainnet (read-only senza chiavi, sicuro per info-only).
# Switch a testnet SOLO quando avrai una API Wallet e vorrai testare il signing path.
HL_NETWORK=mainnet

# === Wallet (API SIGNING ONLY — separate from your master wallet) ===
# Use Hyperliquid's "API Wallet" feature, NOT your master key.
# Create one at https://app.hyperliquid.xyz/API
HL_API_PRIVATE_KEY=
HL_API_WALLET_ADDRESS=
# Master account address (the one with the actual capital).
# The API key signs on behalf of this account.
HL_MASTER_ADDRESS=

# === Trading scope ===
# Comma-separated list. Bot will REFUSE to trade anything not in this allowlist.
HL_ALLOWED_COINS=BTC,ETH,SOL,XRP,BNB

# === Risk limits (HARD) ===
# Bot HALTS automatically if breached. No override.
RISK_MAX_DAILY_LOSS_PCT=2.0           # halt if equity drops >2% in a UTC day
RISK_MAX_POSITION_USD=500             # cap notional per single position
RISK_MAX_TOTAL_EXPOSURE_USD=1500      # cap sum of all open notionals
RISK_MAX_LEVERAGE=3                   # cap leverage per coin (Hyperliquid allows up to 50x)
RISK_MAX_OPEN_POSITIONS=3             # cap concurrent positions
RISK_PER_TRADE_PCT=1.0                # 1% of equity per trade (Kelly fractional, mirror del Simulator)
RISK_RUIN_THRESHOLD_PCT=50            # halt forever if equity < 50% of starting balance

# === Execution guardrails ===
EXEC_DRY_RUN=true                     # if true, log orders but DO NOT send
EXEC_HEARTBEAT_TIMEOUT_SEC=30         # flatten + halt if no price tick for N seconds
EXEC_MIN_TIME_BETWEEN_ORDERS_MS=1000  # rate limit
EXEC_USE_REDUCE_ONLY_FOR_CLOSES=true  # safer
EXEC_DEFAULT_TIF=Gtc                  # Gtc | Ioc | Alo

# === Strategy ===
# Stessa logica del Simulator: 1% risk per trade, compounding, ATR-based SL/TP.
STRATEGY_ENABLED=adaptive,mssChoCH,liqSweep,tripleBarTrap,failedBk,pivotReversal,ictSilverBullet,orderBlockFvg
STRATEGY_TIMEFRAME=15m
STRATEGY_SL_ATR_MULT=1.0
STRATEGY_TP_ATR_MULT=1.8
STRATEGY_MAX_BARS_IN_TRADE=30
STRATEGY_ATR_PERIOD=14

# === Persistence ===
DB_PATH=./data/bot.db
AUDIT_LOG_PATH=./data/audit/signed-payloads.log

# === API server (read-only status + kill-switch) ===
API_PORT=7777
API_BIND=127.0.0.1                    # NEVER expose 0.0.0.0 without auth in front

# === Logging ===
LOG_LEVEL=info                        # trace | debug | info | warn | error
LOG_PRETTY=true
