{
  "name": "hyperliquid-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Piattaforma locale esclusivamente per Hyperliquid — backend bot (Node/TS) + frontend web (React/Vite).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm --prefix web run build",
    "dev": "tsx watch src/orchestrator/main.ts",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "start": "node dist/orchestrator/main.js",
    "backtest": "tsx scripts/backtest-month.ts",
    "optimize": "tsx scripts/optimize-params.ts",
    "dry-run": "tsx scripts/dry-run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "halt": "node -e \"require('fs').writeFileSync('.HALT', new Date().toISOString())\"",
    "resume": "node -e \"require('fs').rmSync('.HALT', { force: true })\""
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@nktkas/hyperliquid": "^0.20.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "viem": "^2.20.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
